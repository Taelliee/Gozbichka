@model GozbichkaWebApp.Models.ViewModels.RecipeDetailsViewModel
@using System.Globalization
@using System.Linq

@{
    ViewData["Title"] = $"{Model.Title} - Gozbichka";

    var ingredientsPerColumn = (int)Math.Ceiling(Model.Ingredients.Count / 2.0);
    var leftIngredients = Model.Ingredients.Take(ingredientsPerColumn).ToList();
    var rightIngredients = Model.Ingredients.Skip(ingredientsPerColumn).ToList();
    var firstStep = Model.Steps.First();
}

<div class="recipe-details-page py-4 py-lg-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb recipe-breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Íŕ÷ŕëî</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" asp-fragment="recipes">Đĺöĺďňč</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>

    <section class="recipe-hero">
        <div class="row g-4 align-items-start">
            <div class="col-lg-6">
                <div class="recipe-image-frame">
                    <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid recipe-image" />
                </div>
            </div>

            <div class="col-lg-6">
                <h1 class="recipe-title-display">@Model.Title</h1>

                <div class="recipe-rating-row">
                    @for (var i = 1; i <= 5; i++)
                    {
                        var starClass = Model.Rating >= i
                            ? "bi-star-fill"
                            : Model.Rating >= i - 0.5
                                ? "bi-star-half"
                                : "bi-star";

                        <i class="bi @starClass"></i>
                    }

                    @if (Model.Rating > 0)
                    {
                        <span class="recipe-rating-text">@Model.Rating.ToString("0.0", CultureInfo.InvariantCulture) / 5</span>
                    }
                    else
                    {
                        <span class="recipe-rating-text">Âńĺ îůĺ í˙ěŕ îöĺíęč</span>
                    }
                </div>

                <p class="recipe-description-text">@Model.Description</p>
            </div>
        </div>
    </section>

    <section class="recipe-summary-grid mt-4">
        <div class="recipe-summary-item">
            <span class="recipe-summary-label">
                <i class="bi bi-people-fill"></i>
                Ďîđöčč
            </span>

            <div class="recipe-portions-control">
                <button type="button" id="decreasePortions" class="recipe-portions-button">-</button>
                <span id="recipePortionsValue" data-base-portions="@Model.Portions">@Model.Portions</span>
                <button type="button" id="increasePortions" class="recipe-portions-button">+</button>
            </div>
        </div>

        <div class="recipe-summary-item">
            <span class="recipe-summary-label">
                <i class="bi bi-grid-fill"></i>
                Ęŕňĺăîđč˙
            </span>
            <strong class="recipe-summary-value">@Model.CategoryName</strong>
        </div>

        <div class="recipe-summary-item">
            <span class="recipe-summary-label">
                <i class="bi bi-bar-chart-fill"></i>
                Ňđóäíîńň
            </span>
            <strong class="recipe-summary-value">@Model.DifficultyName</strong>
        </div>

        <div class="recipe-summary-item">
            <span class="recipe-summary-label">
                <i class="bi bi-clock-fill"></i>
                Âđĺěĺ
            </span>
            <strong class="recipe-summary-value">@Model.CookingTimeText</strong>
        </div>
    </section>

    <section class="recipe-section mt-5">
        <div class="recipe-section-header">
            <h2>
                <i class="bi bi-carrot-fill"></i>
                ÍĹÎÁŐÎÄČĚČ ŃÚŃŇŔÂĘČ
            </h2>
        </div>

        <div class="recipe-ingredients-panel">
            <div class="row g-4">
                <div class="col-md-6 recipe-ingredients-column">
                    @foreach (var ingredient in leftIngredients)
                    {
                        <div class="recipe-ingredient-item">
                            <span class="recipe-ingredient-icon">
                                <i class="bi bi-check-lg"></i>
                            </span>

                            <div class="recipe-ingredient-content">
                                <span class="recipe-ingredient-name">@ingredient.ProductName</span>

                                @if (ingredient.IsOptional)
                                {
                                    <span class="recipe-ingredient-optional">ďî ćĺëŕíčĺ</span>
                                }
                            </div>

                            <span class="recipe-ingredient-amount">
                                <span class="ingredient-quantity"
                                      data-base-quantity="@ingredient.Quantity.ToString(CultureInfo.InvariantCulture)">
                                    @ingredient.QuantityText
                                </span>
                                @ingredient.Unit
                            </span>
                        </div>
                    }
                </div>

                <div class="col-md-6 recipe-ingredients-column">
                    @foreach (var ingredient in rightIngredients)
                    {
                        <div class="recipe-ingredient-item">
                            <span class="recipe-ingredient-icon">
                                <i class="bi bi-check-lg"></i>
                            </span>

                            <div class="recipe-ingredient-content">
                                <span class="recipe-ingredient-name">@ingredient.ProductName</span>

                                @if (ingredient.IsOptional)
                                {
                                    <span class="recipe-ingredient-optional">ďî ćĺëŕíčĺ</span>
                                }
                            </div>

                            <span class="recipe-ingredient-amount">
                                <span class="ingredient-quantity"
                                      data-base-quantity="@ingredient.Quantity.ToString(CultureInfo.InvariantCulture)">
                                    @ingredient.QuantityText
                                </span>
                                @ingredient.Unit
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="recipe-section mt-5">
        <div class="recipe-step-card">
            <div class="recipe-step-body">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <h3 id="recipeStepTitle" class="recipe-step-title">@firstStep.Title</h3>

                    @if (Model.Steps.Count > 1)
                    {
                        <button type="button" id="nextRecipeStep" class="recipe-step-next" aria-label="Ńëĺäâŕůŕ ńňúďęŕ">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    }
                </div>

                <p id="recipeStepDescription" class="recipe-step-description">@firstStep.Description</p>
            </div>

            <div class="recipe-steps-timeline">
                @foreach (var step in Model.Steps)
                {
                    <button type="button"
                            class="recipe-step-button @(step.Number == 1 ? "active" : string.Empty)"
                            data-step-number="@step.Number"
                            data-title="@step.Title"
                            data-description="@step.Description">
                        <span class="recipe-step-button-label">@step.Title</span>
                        <span class="recipe-step-button-dot"></span>
                    </button>
                }
            </div>
        </div>
    </section>

    <section class="most-viewed py-5">
        <div class="container px-0">
            <div class="most-viewed-panel">
                <div class="most-viewed-copy">
                    <h2>Íŕé-ďđĺăëĺćäŕíčňĺ íč đĺöĺďňč</h2>
                    <p>
                        Îňęđčéňĺ íŕřčňĺ íŕé-ďđĺăëĺćäŕíč đĺöĺďňč č ńĺ âäúőíîâĺňĺ çŕ ńëĺäâŕůîňî ńč ăîňâĺíĺ.
                        Âń˙ęŕ đĺöĺďňŕ ĺ âíčěŕňĺëíî ďîäáđŕíŕ, çŕ äŕ âč ďđĺäëîćč âęóńíč č ëĺńíč çŕ ďđčăîňâ˙íĺ ˙ńňč˙.
                    </p>
                </div>

                <div class="most-viewed-cards">
                    <a asp-controller="Recipes" asp-action="RecipeDetails" asp-route-id="2" class="most-viewed-card text-decoration-none">
                        <img src="~/images/qichena.jpg" alt="ßé÷ĺíŕ ńŕëŕňŕ" class="most-viewed-card-image">
                        <div class="most-viewed-card-title">ßé÷ĺíŕ ńŕëŕňŕ</div>
                        <div class="most-viewed-card-subtitle">Ňđŕäčöčîííŕ đĺöĺďňŕ</div>
                    </a>

                    <a asp-controller="Recipes" asp-action="RecipeDetails" asp-route-id="4" class="most-viewed-card text-decoration-none">
                        <img src="~/images/Creme_Brulee.jpg" alt="Ęđĺě áđţëĺ" class="most-viewed-card-image">
                        <div class="most-viewed-card-title">Ęđĺě áđţëĺ</div>
                        <div class="most-viewed-card-subtitle">Ňđŕäčöčîííŕ đĺöĺďňŕ</div>
                    </a>
                </div>

                <div class="most-viewed-arrow" aria-hidden="true">&gt;</div>
            </div>
        </div>
    </section>
</div>

@section Scripts
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const portionsValue = document.getElementById('recipePortionsValue');
            const decreaseButton = document.getElementById('decreasePortions');
            const increaseButton = document.getElementById('increasePortions');
            const quantityElements = document.querySelectorAll('.ingredient-quantity');

            if (portionsValue && decreaseButton && increaseButton) {
                const basePortions = parseInt(portionsValue.dataset.basePortions);
                let currentPortions = basePortions;

                function formatQuantity(value) {
                    const roundedValue = Math.round(value * 100) / 100;
                    const formatted = Number.isInteger(roundedValue)
                        ? roundedValue.toString()
                        : roundedValue.toFixed(2).replace(/\.?0+$/, '');

                    return formatted.replace('.', ',');
                }

                function updateQuantities() {
                    const ratio = currentPortions / basePortions;

                    quantityElements.forEach(function (element) {
                        const baseQuantity = parseFloat(element.dataset.baseQuantity);
                        element.textContent = formatQuantity(baseQuantity * ratio);
                    });

                    portionsValue.textContent = currentPortions;
                }

                decreaseButton.addEventListener('click', function () {
                    if (currentPortions > 1) {
                        currentPortions--;
                        updateQuantities();
                    }
                });

                increaseButton.addEventListener('click', function () {
                    currentPortions++;
                    updateQuantities();
                });
            }

            const stepButtons = Array.from(document.querySelectorAll('.recipe-step-button'));
            const stepTitle = document.getElementById('recipeStepTitle');
            const stepDescription = document.getElementById('recipeStepDescription');
            const nextStepButton = document.getElementById('nextRecipeStep');

            if (stepButtons.length > 0 && stepTitle && stepDescription) {
                let activeStepIndex = 0;

                function setActiveStep(index) {
                    activeStepIndex = index;

                    stepButtons.forEach(function (button, buttonIndex) {
                        button.classList.toggle('active', buttonIndex === index);
                    });

                    stepTitle.textContent = stepButtons[index].dataset.title;
                    stepDescription.textContent = stepButtons[index].dataset.description;
                }

                stepButtons.forEach(function (button, index) {
                    button.addEventListener('click', function () {
                        setActiveStep(index);
                    });
                });

                if (nextStepButton) {
                    nextStepButton.addEventListener('click', function () {
                        const nextIndex = (activeStepIndex + 1) % stepButtons.length;
                        setActiveStep(nextIndex);
                    });
                }
            }
        });
    </script>
}