<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- ADDED: Bootstrap Icons CDN so your icons appear! -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibraryProject.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!-- Top Thin Bar (Dark Brown) -->
        <div class="top-bar py-1 px-4 d-flex justify-content-end align-items-center">
            <div class="top-links d-flex gap-3 align-items-center">
                @{
                    var currentUserId = Context.Session.GetInt32("UserId");
                    var currentUserName = Context.Session.GetString("UserName");
                    var userIcon = Context.Session.GetString("UserIcon") ?? "/images/default-user-icon.png";
                }

                @if (currentUserId.HasValue)
                {
                    <!-- ADMIN SHIELD: Only shows if the Session Role is "Admin" -->
                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <a href="/Admin/Dashboard" class="text-white text-decoration-none small me-2" title="Админ Панел">
                            <i class="bi bi-shield-lock-fill" style="color: #2ec4b6"></i>
                        </a>
                    }

                    <!-- Plain text greeting, no dropdown, no caret -->
                    <span class="text-white small fw-bold me-3">
                        Здравей, @currentUserName!
                    </span>

                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-link text-white text-decoration-none small p-0"><i class="bi bi-box-arrow-right" style="color: #2ec4b6"></i> ИЗХОД</button>
                    </form>
                }
                else
                {
                    <!-- Guest links (Notice the shield is gone from here!) -->
                    <a href="#" class="text-white text-decoration-none small" data-bs-toggle="modal" data-bs-target="#registerModal"><i class="bi bi-megaphone" style="color: #2ec4b6"></i> РЕГИСТРАЦИЯ</a>
                    <a href="#" class="text-white text-decoration-none small" data-bs-toggle="modal" data-bs-target="#loginModal"><i class="bi bi-person" style="color: #2ec4b6"></i> ВХОД</a>
                }
            </div>
        </div>

        <!-- Main Navigation Bar (Orange) -->
        <nav class="navbar navbar-expand-lg nav-orange py-2 px-4 shadow-sm">
            <div class="container-fluid">
                <!-- Logo -->
                <a class="navbar-brand me-4" href="/">
                    <img src="~/images/hatLogo.png" alt="Gozbichka Logo" height="80">
                </a>

                <!-- Links -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    @{
                        // This grabs the name of the current page you are on
                        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                    }
    
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 fw-bold align-items-center">
                        <li class="nav-item">
                            <a class="nav-link me-3 @(currentController == "Home" && currentAction == "Index" ? "active-link" : "text-dark")"
                               asp-controller="Home" asp-action="Index">Начало</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link me-3 text-dark" href="/#recipes">Рецепти</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link me-3 @(currentController == "Refrigerator" ? "active-link" : "text-dark")"
                               asp-controller="Refrigerator" asp-action="Index">Хладилник</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link me-3 text-dark" href="/#contacts">Контакти</a>
                        </li>
                    </ul>

                    <!-- Search Bar -->
                    <div class="d-flex align-items-center me-3">
                        <div class="search-container d-flex align-items-center bg-white rounded-pill p-1 shadow-sm">
                            <select class="form-select navbar-search-select category-select border-0 bg-transparent rounded-pill px-3" style="width: 180px;">
                                <option value="">Всички категории</option>
                                <option value="Салати">Салати</option>
                                <option value="Основни">Основни</option>
                                <option value="Супи">Супи</option>
                                <option value="Десерти">Десерти</option>
                            </select>
                            <div class="divider"></div>
                            <input class="form-control border-0 bg-transparent" type="search" placeholder="Търсене">
                            <button class="btn btn-search rounded-circle" type="button">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>

                    <!-- User & Menu Icon -->
                    <div class="d-flex align-items-center gap-3">
                        @if (currentUserId.HasValue)
                        {
                            <!-- Display the Profile Picture Dropdown HERE -->
                            <div class="dropdown">
                                <a href="#" class="d-block" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="@userIcon" alt="Profile" class="rounded-circle border border-white" style="width: 40px; height: 40px; object-fit: cover;">
                                </a>
                    
                                <!-- Dropdown Menu for Profile Actions -->
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="profileDropdown">
                                    <li class="px-3 py-2">
                                        <!-- The Upload Form -->
                                        <form asp-controller="Account" asp-action="UploadProfilePicture" method="post" enctype="multipart/form-data" class="d-flex flex-column gap-2">
                                            <label for="profileImage" class="form-label small fw-bold mb-0">Смени снимка:</label>
                                            <input type="file" name="profileImage" id="profileImage" class="form-control form-control-sm" accept="image/*" required>
                                            <button type="submit" class="btn btn-warning btn-sm w-100">Качи</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <!-- Static image for guests -->
                            <img src="@userIcon" class="rounded-circle border border-white" style="width: 40px; height: 40px; object-fit: cover;" alt="User Profile">
                        }

                        <button class="btn border-0 p-0 text-dark">
                            <i class="bi bi-list fs-1"></i> <!-- This is the hamburger icon -->
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Login Modal -->
    <partial name="_LoginModal" />

    <!-- Register Modal -->
    <partial name="_RegisterModal" />

    <footer class="footer-custom py-5 mt-5">
        <div class="container">
            <div class="row align-items-top">
                <!-- Column 1: Fresh Recipe -->
                <div class="col-md-2 mb-4">
                    <h5 class="footer-heading">Fresh Recipe</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Recipes</a></li>
                        <li><a href="#">Winter salads</a></li>
                        <li><a href="#">Organic chicken</a></li>
                        <li><a href="#">Beef and Mutton</a></li>
                        <li><a href="#">Flavoured Milk</a></li>
                    </ul>
                </div>

                <!-- Column 2: In News -->
                <div class="col-md-2 mb-4">
                    <h5 class="footer-heading">In News</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Our Blogs</a></li>
                        <li><a href="#">Contests/Sweepsatkes</a></li>
                        <li><a href="#">Video</a></li>
                        <li><a href="#">New Releases</a></li>
                        <li><a href="#">Newsletters</a></li>
                    </ul>
                </div>

                <!-- Column 3: About US -->
                <div class="col-md-2 mb-4">
                    <h5 class="footer-heading">About US</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">FAQ</a></li>
                        <li><a href="#">Our Board</a></li>
                        <li><a href="#">Our Staff</a></li>
                        <li><a href="#">Contact Us</a></li>
                    </ul>
                </div>

                <!-- Column 4: Center Logo -->
                <div class="col-md-2 text-center mb-4">
                    <div class="footer-logo-circle mx-auto">
                        <img src="~/images/hatLogoFilled.png" alt="Gozbichka Logo" class="img-fluid">
                    </div>
                </div>

                <!-- Column 5: Subscription & Socials -->
                <div class="col-md-4 mb-4">
                    <h4 class="text-white mb-3 fw-light">Абониране за бюлетина</h4>
                    <div class="input-group newsletter-group mb-3">
                        <input type="email" class="form-control footer-input" placeholder="Email">
                        <button class="btn footer-submit" type="button">
                            <i class="bi bi-envelope-at"></i>
                        </button>
                    </div>
                    <div class="social-icons d-flex gap-3">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-twitter-x"></i></a>
                        <a href="#"><i class="bi bi-pinterest"></i></a>
                        <a href="#"><i class="bi bi-youtube"></i></a>
                    </div>
                    <p class="text-end text-light small mt-4 opacity-75">All Rights Reserved</p>
                </div>
            </div>
        </div>
    </footer>
    <!-- Render the Modals -->
    <partial name="_LoginModal" />
    <partial name="_RegisterModal" />

    <!-- Render Success/Error Messages from AccountController -->
    @if (TempData["LoginError"] != null || TempData["RegisterError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show position-fixed top-0 end-0 m-3" style="z-index: 1050;" role="alert">
            @(TempData["LoginError"] ?? TempData["RegisterError"])
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["LoginSuccess"] != null || TempData["RegisterSuccess"] != null || TempData["LogoutSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show position-fixed top-0 end-0 m-3" style="z-index: 1050;" role="alert">
            @(TempData["LoginSuccess"] ?? TempData["RegisterSuccess"] ?? TempData["LogoutSuccess"])
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
