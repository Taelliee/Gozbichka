<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibraryProject</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- ADDED: Bootstrap Icons CDN so your icons appear! -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibraryProject.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!-- Top Thin Bar (Dark Brown) -->
        <div class="top-bar py-1 px-4 d-flex justify-content-end align-items-center">
            <div class="top-links d-flex gap-3">
                <a href="#" class="text-white text-decoration-none small"><i class="bi bi-megaphone"></i> РЕГИСТРАЦИЯ</a>
                <a href="#" class="text-white text-decoration-none small"><i class="bi bi-person"></i> ВХОД</a>
                <a href="#" class="text-white text-decoration-none small"><i class="bi bi-shield-lock"></i></a>
            </div>
        </div>

        <!-- Main Navigation Bar (Orange) -->
        <nav class="navbar navbar-expand-lg nav-orange py-2 px-4 shadow-sm">
            <div class="container-fluid">
                <!-- Logo -->
                <a class="navbar-brand me-4" href="/">
                    <img src="https://placehold.co/60x60?text=Logo" alt="Gozbichka Logo" height="60">
                </a>

                <!-- Links -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 fw-bold">
                        <li class="nav-item">
                            <a class="nav-link active-link me-3" href="/">Начало</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link me-3 text-dark" href="#">Рецепти</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link me-3 text-dark" href="#">Хладилник</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link me-3 text-dark" href="#">Контакти</a>
                        </li>
                    </ul>

                    <!-- Search Bar -->
                    <div class="d-flex align-items-center me-3">
                        <div class="search-container d-flex align-items-center bg-white rounded-pill p-1 shadow-sm">
                            <select class="form-select category-select border-0 bg-transparent rounded-pill px-3" style="width: 180px;">
                                <option>Всички категории</option>
                            </select>
                            <div class="divider"></div>
                            <input class="form-control border-0 bg-transparent" type="search" placeholder="Търсене">
                            <button class="btn btn-search rounded-circle" type="button">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>

                    <!-- User & Menu Icon -->
                    <div class="d-flex align-items-center gap-3">
                        <img src="https://placehold.co/40x40" class="rounded-circle border border-white" alt="User Profile">
                        <button class="btn border-0 p-0 text-dark">
                            <i class="bi bi-list fs-1"></i> <!-- This is the hamburger icon -->
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom py-5 mt-5">
        <div class="container">
            <div class="row align-items-top">
                <!-- Column 1: Fresh Recipe -->
                <div class="col-md-2 mb-4">
                    <h5 class="footer-heading">Fresh Recipe</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Recipes</a></li>
                        <li><a href="#">Winter salads</a></li>
                        <li><a href="#">Organic chicken</a></li>
                        <li><a href="#">Beef and Mutton</a></li>
                        <li><a href="#">Flavoured Milk</a></li>
                    </ul>
                </div>

                <!-- Column 2: In News -->
                <div class="col-md-2 mb-4">
                    <h5 class="footer-heading">In News</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Our Blogs</a></li>
                        <li><a href="#">Contests/Sweepsatkes</a></li>
                        <li><a href="#">Video</a></li>
                        <li><a href="#">New Releases</a></li>
                        <li><a href="#">Newsletters</a></li>
                    </ul>
                </div>

                <!-- Column 3: About US -->
                <div class="col-md-2 mb-4">
                    <h5 class="footer-heading">About US</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">FAQ</a></li>
                        <li><a href="#">Our Board</a></li>
                        <li><a href="#">Our Staff</a></li>
                        <li><a href="#">Contact Us</a></li>
                    </ul>
                </div>

                <!-- Column 4: Center Logo -->
                <div class="col-md-2 text-center mb-4">
                    <div class="footer-logo-circle mx-auto">
                        <img src="https://placehold.co/120x120?text=Logo" alt="Gozbichka Logo" class="img-fluid">
                    </div>
                </div>

                <!-- Column 5: Subscription & Socials -->
                <div class="col-md-4 mb-4">
                    <h4 class="text-white mb-3 fw-light">Абониране за бюлетина</h4>
                    <div class="input-group newsletter-group mb-3">
                        <input type="email" class="form-control footer-input" placeholder="Email">
                        <button class="btn footer-submit" type="button">
                            <i class="bi bi-envelope-at"></i>
                        </button>
                    </div>
                    <div class="social-icons d-flex gap-3">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-twitter-x"></i></a>
                        <a href="#"><i class="bi bi-pinterest"></i></a>
                        <a href="#"><i class="bi bi-youtube"></i></a>
                    </div>
                    <p class="text-end text-light small mt-4 opacity-75">All Rights Reserved</p>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
