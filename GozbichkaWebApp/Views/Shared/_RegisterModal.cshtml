<!-- Register Modal -->
<div class="modal fade" id="registerModal" tabindex="-1" aria-labelledby="registerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow">
            <div class="modal-body p-5">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>

                <h2 class="text-center mb-4 fw-bold">Регистрация</h2>

                @if (TempData["RegisterError"] != null)
                {
                    <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-x-circle-fill me-2"></i>
                        <small>@TempData["RegisterError"]</small>
                    </div>
                }

                <form id="registerForm" asp-controller="Account" asp-action="Register" method="post" novalidate autocomplete="off">

                    <input type="text" style="display:none" tabindex="-1" aria-hidden="true" autocomplete="username">
                    <input type="password" style="display:none" tabindex="-1" aria-hidden="true" autocomplete="new-password">

                    <div class="mb-3">
                        <label for="registerEmail" class="form-label fw-semibold">Email</label>
                        <input type="email" class="form-control" id="registerEmail" name="Email" autocomplete="off">
                        <div class="field-error text-danger small mt-1" id="emailError"></div>
                    </div>

                    <div class="mb-3">
                        <label for="registerUserName" class="form-label fw-semibold">Потребителско име</label>
                        <input type="text" class="form-control" id="registerUserName" name="UserName" autocomplete="off">
                        <div class="field-error text-danger small mt-1" id="userNameError"></div>
                    </div>

                    <div class="mb-3">
                        <label for="registerPassword" class="form-label fw-semibold">Парола</label>
                        <input type="password" class="form-control" id="registerPassword" name="Password" autocomplete="new-password">
                        <div class="field-error text-danger small mt-1" id="passwordError"></div>
                    </div>

                    <div class="mb-4">
                        <label for="registerConfirmPassword" class="form-label fw-semibold">Повтори парола</label>
                        <input type="password" class="form-control" id="registerConfirmPassword" name="ConfirmPassword" autocomplete="new-password">
                        <div class="field-error text-danger small mt-1" id="confirmPasswordError"></div>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 py-2 fw-semibold rounded-pill">Регистрирай се</button>

                    <p class="text-center mt-3 mb-0">
                        <small>Вече имаш профил? <a href="#" class="text-warning text-decoration-none switch-to-login">Влез</a></small>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

@if (TempData["RegisterError"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            new bootstrap.Modal(document.getElementById('registerModal')).show();
        });
    </script>
}

<script>
    document.getElementById('registerForm').addEventListener('submit', function (e) {
        let valid = true;

        const email = document.getElementById('registerEmail');
        const userName = document.getElementById('registerUserName');
        const password = document.getElementById('registerPassword');
        const confirm = document.getElementById('registerConfirmPassword');

        clearErrors();

        const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        if (!email.value.trim()) {
            showError('emailError', email, 'Имейлът е задължителен.');
            valid = false;
        } else if (!emailRegex.test(email.value.trim())) {
            showError('emailError', email, 'Невалиден имейл адрес.');
            valid = false;
        }

        if (!userName.value.trim()) {
            showError('userNameError', userName, 'Потребителското име е задължително.');
            valid = false;
        } else if (userName.value.trim().length < 3) {
            showError('userNameError', userName, 'Потребителското име трябва да е поне 3 символа.');
            valid = false;
        }

        if (!password.value) {
            showError('passwordError', password, 'Паролата е задължителна.');
            valid = false;
        } else if (password.value.length < 6) {
            showError('passwordError', password, 'Паролата трябва да е поне 6 символа.');
            valid = false;
        }

        if (!confirm.value) {
            showError('confirmPasswordError', confirm, 'Моля, повторете паролата.');
            valid = false;
        } else if (confirm.value !== password.value) {
            showError('confirmPasswordError', confirm, 'Паролите не съвпадат.');
            valid = false;
        }

        if (!valid) e.preventDefault();
    });

    function showError(errorId, input, message) {
        document.getElementById(errorId).textContent = message;
        input.classList.add('is-invalid');
    }

    function clearErrors() {
        document.querySelectorAll('#registerForm .field-error').forEach(el => el.textContent = '');
        document.querySelectorAll('#registerForm .form-control').forEach(el => el.classList.remove('is-invalid'));
    }
</script>

<style>
    #registerModal .modal-content {
        border: none;
        max-width: 450px;
        margin: 0 auto;
    }

    #registerModal .btn-warning {
        background-color: #f8a146;
        border-color: #f8a146;
        color: white;
    }

        #registerModal .btn-warning:hover {
            background-color: #e89135;
            border-color: #e89135;
        }

    #registerModal .form-control:focus {
        border-color: #f8a146;
        box-shadow: 0 0 0 0.25rem rgba(248, 161, 70, 0.25);
    }

    #registerModal .alert-warning {
        background-color: #fff3cd;
        border-color: #ffc107;
        color: #856404;
    }

    #registerModal .form-control.is-invalid {
        border-color: #dc3545;
    }
</style>