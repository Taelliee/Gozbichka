<!-- Login Modal -->
<div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow">
            <div class="modal-body p-5">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>

                <h2 class="text-center mb-4 fw-bold">Вход</h2>

                <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <small>Попълнете Вашите данни, за да влезете в профила си</small>
                </div>

                <form id="loginForm" asp-controller="Account" asp-action="Login" method="post">
                    <div class="mb-3">
                        <label for="loginEmail" class="form-label fw-semibold">Email</label>
                        <input type="email" class="form-control" id="loginEmail" name="Email" required>
                    </div>

                    <div class="mb-3">
                        <label for="loginPassword" class="form-label fw-semibold">Парола</label>
                        <input type="password" class="form-control" id="loginPassword" name="Password" required>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe" name="RememberMe">
                            <label class="form-check-label" for="rememberMe">
                                Запомни ме
                            </label>
                        </div>
                        <a href="#" class="text-decoration-none text-warning">Забравена парола</a>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 py-2 fw-semibold rounded-pill">Влез</button>

                    <p class="text-center mt-3 mb-0">
                        <small>Нов потребител? <a href="#" class="text-warning text-decoration-none switch-to-register">Регистрирай се</a></small>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    #loginModal .modal-content {
        border: none;
        max-width: 450px;
        margin: 0 auto;
    }

    #loginModal .btn-warning {
        background-color: #ff9f1c;
        border-color: #ff9f1c;
        color: white;
    }

    #loginModal .btn-warning:hover {
        background-color: #ff9f1c;
        border-color: #ff9f1c;
    }

    #loginModal .form-control:focus {
        border-color: #f8a146;
        box-shadow: 0 0 0 0.25rem rgba(248, 161, 70, 0.25);
    }

    #loginModal .alert-warning {
        background-color: #fff3cd;
        border-color: #ffc107;
        color: #856404;
    }
</style>