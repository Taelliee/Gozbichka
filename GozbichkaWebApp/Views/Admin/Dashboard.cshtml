@{
    ViewData["Title"] = "Админ";
}

<div class="admin-dashboard-container mx-auto mt-4 shadow-sm" style="max-width: 900px;">
    
    <!-- Header Section (Dark Brown) -->
    <div class="admin-header p-4 text-center">
        <h2 class="text-white fw-bold mb-4" style="font-family: 'Georgia', serif;">Управление на рецепти</h2>
        
        <!-- Tabs -->
        <div class="d-flex justify-content-center gap-3">
            <button id="btnTabAdd" onclick="switchTab('add')" class="btn admin-tab tab-active fw-bold px-4 py-2 border-0 d-flex align-items-center justify-content-center gap-2">
                Добави рецепта <span class="text-teal fs-5" style="line-height: 0;">+</span>
            </button>
            <button id="btnTabEdit" onclick="switchTab('edit')" class="btn admin-tab tab-inactive fw-bold px-4 py-2 border-0 d-flex align-items-center justify-content-center gap-2">
                Редактирай рецепта <i class="bi bi-pencil-fill text-teal"></i>
            </button>
            <button id="btnTabDelete" onclick="switchTab('delete')" class="btn admin-tab tab-inactive fw-bold px-4 py-2 border-0 d-flex align-items-center justify-content-center gap-2">
                Изтрий рецепта <i class="bi bi-trash-fill text-teal"></i>
            </button>
        </div>
    </div>

    <!-- Form Section (Mint/Cyan) -->
    <div id="sectionAdd" class="admin-body p-5">
        <div class="text-center mb-4">
            <h3 class="fw-bold" style="color: #5d4037; font-family: 'Georgia', serif;">
                <i class="bi bi-egg-fried text-teal me-2 fs-2"></i>ДОБАВЯНЕ НА РЕЦЕПТА
            </h3>
        </div>

        <form asp-controller="Admin" asp-action="AddRecipe" method="post" enctype="multipart/form-data">
            
            <!-- Заглавие (Title) -->
            <div class="mb-4">
                <label class="form-label fw-bold small text-brown">Заглавие</label>
                <input type="text" name="Title" class="form-control form-control-line" required>
            </div>

            <!-- Категория & Трудност -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold small text-brown">Категория</label>
                    <select name="MealCategoryId" class="form-select form-control-rounded" required>
                        <option value="">Избери категория</option>
                        @foreach (var category in ViewBag.Categories)
                        {
                            <option value="@category.MealCategoryId">@category.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small text-brown">Трудност</label>
                    <select name="DifficultyId" class="form-select form-control-rounded" required>
                        <option value="">Избери трудност</option>
                        @foreach (var difficulty in ViewBag.Difficulties)
                        {
                            <option value="@difficulty.DifficultyId">@difficulty.DifficultyType.ToString()</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Време за готвене -->
            <div class="mb-4">
                <label class="form-label fw-bold small text-brown d-block">Време за готвене</label>
                <div class="d-flex gap-3" style="max-width: 300px;">
                    <input type="number" name="CookTimeMinutes" class="form-control form-control-rounded" placeholder="Минути">
                    <input type="number" name="CookTimeHours" class="form-control form-control-rounded" placeholder="Часове">
                </div>
            </div>

            <!-- Порции & Продукти -->
            <div class="row mb-4">
                
                <!-- Порции -->
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-brown">Порции</label>
                    <input type="number" name="Portions" class="form-control form-control-rounded" value="1" min="1" required>
                </div>

                <!-- Продукти (Dynamic Builder) -->
                <div class="col-md-9">
                    <label class="form-label fw-bold small text-brown">Добави продукти</label>
                    
                    <!-- The Input Row -->
                    <div class="d-flex gap-2 mb-2">
                        
                        <!-- Product Selection Wrapper -->
                        <div style="flex: 4; min-width: 0;">
                            <select id="productSelect" class="form-select form-control-rounded" style="width: 100%;">
                                <option value="">Избери продукт...</option>
                                @foreach (var product in ViewBag.Products)
                                {
                                    <option value="@product.ProductId">@product.ProductName</option>
                                }
                            </select>
                        </div>

                        <!-- Quantity Wrapper -->
                        <div style="flex: 2; min-width: 70px;">
                            <input type="number" id="productQuantity" class="form-control form-control-rounded w-100" placeholder="Кол." min="0.1" step="0.1">
                        </div>

                        <!-- Unit Wrapper -->
                        <div style="flex: 2; min-width: 80px;">
                            <select id="productUnit" class="form-select form-control-rounded w-100">
                                <option value="бр.">бр.</option>
                                <option value="ч. л.">ч. л.</option>
                                <option value="с. л.">с. л.</option>
                                <option value="ч. ч.">ч. ч.</option>
                                <option value="к. ч.">к. ч.</option>
                                <option value="гр.">гр.</option>
                                <option value="кг.">кг.</option>
                                <option value="мл.">мл.</option>
                                <option value="л.">л.</option>
                                <option value="щипка/и">щипка/и</option>
                            </select>
                        </div>

                        <!-- Button Wrapper -->
                        <div>
                            <button type="button" id="addProductBtn" class="btn text-white fw-bold px-3 shadow-sm h-100" style="background-color: #26a69a; border-radius: 12px; font-size: 1.2rem; line-height: 1;">+</button>
                        </div>
                        
                    </div>

                    <div id="selectedProductsList" class="d-flex flex-column gap-2 mt-3">
                    </div>
                </div>
            </div>

            <!-- Описание -->
            <div class="mb-4">
                <label class="form-label fw-bold small text-brown">Описание</label>
                <textarea name="Description" class="form-control form-control-rounded" rows="3"></textarea>
            </div>

            <!-- Метод на приготвяне -->
            <div class="mb-4">
                <label class="form-label fw-bold small text-brown">Метод на приготвяне</label>
                <textarea name="Method" class="form-control form-control-rounded" rows="4"></textarea>
            </div>

            <!-- Снимка -->
            <div class="mb-5">
                <label class="form-label fw-bold small text-brown d-block">Снимка</label>
                <div class="d-flex align-items-center gap-3">
                    <label for="recipeImage" class="btn bg-white text-dark-brown border border-secondary rounded-pill px-4 py-1 small mb-0" style="cursor: pointer;">
                        Качи снимка <span class="ms-2">+</span>
                    </label>
                    <input type="file" id="recipeImage" name="Image" class="d-none" accept="image/*">
                    
                    <div id="imagePreviewContainer" class="d-none align-items-center gap-2">
                        <img id="imagePreview" src="#" alt="Preview" class="rounded shadow-sm" style="width: 60px; height: 60px; object-fit: cover; border: 2px solid #26a69a;">
                        <span id="imageFileName" class="small text-muted fw-semibold"></span>
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="text-center mt-5">
                <button type="submit" class="btn text-white fw-bold px-5 py-2 fs-5" style="background-color: #f89c1e; border-radius: 25px; width: 300px;">
                    Добави Рецепта
                </button>
            </div>
        </form>
    </div>

    <!-- Edit Section -->
    <div id="sectionEdit" class="admin-body p-5 d-none">
        <div class="text-center mb-4">
            <h3 class="fw-bold" style="color: #5d4037; font-family: 'Georgia', serif;">
                <i class="bi bi-pencil-square text-teal me-2 fs-2"></i>РЕДАКТИРАЙ РЕЦЕПТА
            </h3>
        </div>

        <div class="bg-white rounded-3 p-3 shadow-sm">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-brown">
                    <tr>
                        <th>Снимка</th>
                        <th>Заглавие</th>
                        <th>Категория</th>
                        <th class="text-end">Действие</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var recipe in ViewBag.AllRecipes)
                    {
                        <tr>
                            <td>
                                <img src="@recipe.ImageURL" alt="Recipe" class="rounded" style="width: 50px; height: 50px; object-fit: cover;">
                            </td>
                            <td class="fw-bold text-brown">@recipe.Title</td>
                            <td><span class="badge text-brown">@recipe.MealCategory?.Name</span></td>
                            <td class="text-end">
                                <a asp-controller="Admin" asp-action="EditRecipe" asp-route-id="@recipe.RecipeId" class="btn btn-sm btn-warning fw-bold text-white shadow-sm rounded-pill px-3">
                                    Редактирай
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Delete Section -->
    <div id="sectionDelete" class="admin-body p-5 d-none">
        <div class="text-center mb-4">
            <h3 class="fw-bold text-danger" style="font-family: 'Georgia', serif;">
                <i class="bi bi-trash-fill me-2 fs-2"></i>ИЗТРИЙ РЕЦЕПТА
            </h3>
            <p class="text-muted small">Внимание: Изтриването на рецепта е необратимо действие!</p>
        </div>

        <div class="bg-white rounded-3 p-3 shadow-sm">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-brown">
                    <tr>
                        <th>Снимка</th>
                        <th>Заглавие</th>
                        <th>Категория</th>
                        <th class="text-end">Действие</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var recipe in ViewBag.AllRecipes)
                    {
                        <tr>
                            <td>
                                <img src="@recipe.ImageURL" alt="Recipe" class="rounded" style="width: 50px; height: 50px; object-fit: cover;">
                            </td>
                            <td class="fw-bold text-brown">@recipe.Title</td>
                            <td><span class="badge text-brown">@recipe.MealCategory?.Name</span></td>
                            <td class="text-end">
                                <form asp-controller="Admin" asp-action="DeleteRecipe" asp-route-id="@recipe.RecipeId" method="post" 
                                      onsubmit="return confirm('Сигурни ли сте, че искате да изтриете рецептата @recipe.Title? Това действие е необратимо!');">
                                    <button type="submit" class="btn btn-sm btn-danger fw-bold text-white shadow-sm rounded-pill px-3">
                                        Изтрий
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    /* Colors */
    .admin-header { background-color: #5d4037; border-top-left-radius: 8px; border-top-right-radius: 8px; }
    .admin-body { background-color: #d1f2eb; border-bottom-left-radius: 8px; border-bottom-right-radius: 8px; }
    .text-brown { color: #5d4037; }
    .text-teal { color: #26a69a; }
    .bg-teal { background-color: #26a69a; }

    /* Tabs */
    .admin-tab { border-radius: 8px; }
    .tab-active { background-color: #d1f2eb; color: #5d4037; border: 2px solid #d1f2eb; }
    .tab-active:hover { background-color: #bce8e0; color: #5d4037; }
    .tab-inactive { background-color: #f5b041; color: #5d4037; border: 2px solid #f5b041; }
    .tab-inactive:hover { background-color: #e67e22; color: white; }

    /* Form Inputs */
    .form-control-line {
        background: transparent;
        border: none;
        border-bottom: 1px solid #5d4037;
        border-radius: 0;
        padding-left: 0;
    }
    .form-control-line:focus {
        background: transparent;
        box-shadow: none;
        border-color: #26a69a;
    }
    .form-control-rounded {
        border-radius: 12px;
        border: 1px solid #aab7b8;
    }
    .form-control-rounded:focus {
        border-color: #26a69a;
        box-shadow: 0 0 0 0.25rem rgba(38, 166, 154, 0.25);
    }

    /* Select2 Custom Styling to Match Your Theme */
    .select2-container .select2-selection--single {
        height: 38px !important;
        border-radius: 12px !important;
        border: 1px solid #aab7b8 !important;
        display: flex !important;
        align-items: center !important;
        padding-left: 0.375rem;
    }
    .select2-container--default .select2-selection--single .select2-selection__rendered {
        color: #5d4037 !important;
    }
    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 36px !important;
    }
    .select2-container--default .select2-selection--single:focus,
    .select2-container--open .select2-selection--single {
        border-color: #26a69a !important;
        box-shadow: 0 0 0 0.25rem rgba(38, 166, 154, 0.25) !important;
        outline: none;
    }
</style>
@section Scripts {
    <!-- Select2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        function switchTab(tabName) {
            document.getElementById('sectionAdd').classList.add('d-none');
            document.getElementById('sectionEdit').classList.add('d-none');
            document.getElementById('sectionDelete').classList.add('d-none'); 

            const inactiveClass = 'btn admin-tab tab-inactive fw-bold px-4 py-2 border-0 d-flex align-items-center justify-content-center gap-2';
            document.getElementById('btnTabAdd').className = inactiveClass;
            document.getElementById('btnTabEdit').className = inactiveClass;
            document.getElementById('btnTabDelete').className = inactiveClass;

            const activeClass = 'btn admin-tab tab-active fw-bold px-4 py-2 border-0 d-flex align-items-center justify-content-center gap-2';
            
            if (tabName === 'add') {
                document.getElementById('sectionAdd').classList.remove('d-none');
                document.getElementById('btnTabAdd').className = activeClass;
            } else if (tabName === 'edit') {
                document.getElementById('sectionEdit').classList.remove('d-none');
                document.getElementById('btnTabEdit').className = activeClass;
            } else if (tabName === 'delete') {
                document.getElementById('sectionDelete').classList.remove('d-none');
                document.getElementById('btnTabDelete').className = activeClass;
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            switchTab('add');

            if (window.jQuery) {
                $('select[name="MealCategoryId"]').select2({ width: '100%' });
                $('#productSelect').select2({ width: '100%' });
            }

            const imageInput = document.getElementById('recipeImage');
            const imagePreviewContainer = document.getElementById('imagePreviewContainer');
            const imagePreview = document.getElementById('imagePreview');
            const imageFileName = document.getElementById('imageFileName');

            imageInput.addEventListener('change', function () {
                const file = this.files[0];
                if (file) {
                    imagePreview.src = URL.createObjectURL(file);
                    imageFileName.textContent = file.name;
                    imagePreviewContainer.classList.remove('d-none');
                    imagePreviewContainer.classList.add('d-flex');
                } else {
                    imagePreviewContainer.classList.add('d-none');
                    imagePreviewContainer.classList.remove('d-flex');
                    imagePreview.src = '#';
                    imageFileName.textContent = '';
                }
            });

            const addBtn = document.getElementById('addProductBtn');
            const productSelect = document.getElementById('productSelect');
            const quantityInput = document.getElementById('productQuantity');
            const unitSelect = document.getElementById('productUnit');
            const listContainer = document.getElementById('selectedProductsList');
            
            let productIndex = 0;

            addBtn.addEventListener('click', function () {
                const productId = productSelect.value;
                const productName = productSelect.options[productSelect.selectedIndex]?.text;
                const quantity = quantityInput.value;
                const unit = unitSelect.value;

                if (!productId || !quantity) {
                    alert('Моля, изберете продукт и въведете количество.');
                    return;
                }

                const itemDiv = document.createElement('div');
                itemDiv.className = 'd-flex justify-content-between align-items-center bg-white p-2 px-3 border rounded shadow-sm';
                itemDiv.style.borderColor = '#aab7b8';

                itemDiv.innerHTML = `
                    <div>
                        <i class="bi bi-check-circle-fill text-teal me-2"></i>
                        <span class="fw-bold text-brown">${productName}</span>
                        <span class="text-muted ms-2">- ${quantity} ${unit}</span>
                    </div>
                    <button type="button" class="btn btn-sm btn-danger rounded-circle remove-btn" style="width: 25px; height: 25px; padding: 0; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-x"></i>
                    </button>
                    <input type="hidden" name="RecipeProducts[${productIndex}].ProductId" value="${productId}">
                    <input type="hidden" name="RecipeProducts[${productIndex}].Quantity" value="${quantity}">
                    <input type="hidden" name="RecipeProducts[${productIndex}].Unit" value="${unit}">
                `;

                itemDiv.querySelector('.remove-btn').addEventListener('click', function () {
                    itemDiv.remove();
                });

                listContainer.appendChild(itemDiv);

                productSelect.value = '';
                quantityInput.value = '';
                unitSelect.value = 'бр.'; 
                
                if (window.jQuery) { $(productSelect).trigger('change'); }
                
                productIndex++;
            });
        });
    </script>
}