@{
    ViewData["Title"] = "Gozbichka - Prototype";
}

<div class="container-fluid p-0">
    <!-- Hero Section -->
    <section class="hero-section d-flex align-items-center bg-#fff3e4 py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <img src="~/images/perhapsASalad.png" class="img-fluid shadow" alt="Salad">
                </div>
                <div class="col-md-6 px-5">
                    <h1 class="text-teal">Добре дошли в Гозбичка!</h1>
                    <p>
                        Добре дошли в Гозбичка – уютното кътче за вдъхновение в кухнята и любов към домашно приготвената храна. Тук ще откриете вкусни рецепти за всеки ден – от бързи и лесни ястия до идеи за специални моменти с любимите хора.
                        <br /><br />
                        В Гозбичка вярваме, че най-хубавите ястия се приготвят с грижа и сърце. Затова ще намерите рецепти с достъпни съставки и ясни стъпки, които превръщат готвенето в приятно и споделено изживяване.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Categories Section -->
    <section class="categories-section py-5" style="background-color: #61493c;">
        <h2 class="text-center mb-4" style="color: #ffbf69; font-family: 'Georgia', serif;">Категории</h2>
        <div class="container">
            <div class="row g-4 justify-content-center">
                @{
                    // Define the categories and their exact image filenames
                    var categories = new[] {
                    new { Name = "Салати", ImageFile = "Salad_Caesar.jpg" },
                    new { Name = "Основни", ImageFile = "MainDish.jpg" },
                    new { Name = "Супи", ImageFile = "Soup.jpeg" },
                    new { Name = "Десерти", ImageFile = "Dessert.jpg" }
                };
                }

                @foreach (var cat in categories)
                {
                    <div class="col-6 col-md-2">
                        <div class="p-3 rounded text-center shadow-sm" style="background-color: #fff3e4">
                            <img src="~/images/@cat.ImageFile" class="img-fluid rounded mb-2" alt="@cat.Name" style="width: 150px; height: 100px; object-fit: cover;">
                            <h5 class="m-0" style="color: #61493c">@cat.Name</h5>
                        </div>
                    </div>
                }
            </div>
            <p class="text-center mt-4" style="color: #ffbf69; font-style: italic">И още много...</p>
        </div>
    </section>
    <br />
    <!-- Seasonal Offers (Slider) -->
    <section class="seasonal-offers py-5" style="background-color: #ff9f1c;">
        <div class="container text-center">
            <h2 style="color: #5d4037;">Сезонни предложения</h2>
            <p style="color: #5d4037;">Вкусни идеи, вдъхновени от сезона</p>

            <div id="seasonalCarousel" class="carousel slide mt-4" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <!-- Slide 1 -->
                    <div class="carousel-item active">
                        <div class="row justify-content-center px-5 pt-4">
                            <div class="col-md-3 d-none d-md-block">
                                <div class="recipe-card bg-white rounded shadow position-relative mx-2">
                                    <div class="badge-new">НОВА РЕЦЕПТА</div>
                                    <img src="~/images/Chocolate_Souffle.jpg" class="card-img-top p-3" style="height: 200px; width: 100%; object-fit: cover;">
                                    <div class="card-body p-3 text-center">
                                        <h5>Шоколадово суфле</h5>
                                        <p class="small text-muted">Само за 30 минути можете да си приготвите...</p>
                                        <button class="btn btn-info text-white w-100 btn-teal">Прегледай</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 d-none d-md-block">
                                <div class="recipe-card bg-white rounded shadow position-relative mx-2">
                                    <img src="~/images/Spaghetti.webp" class="card-img-top p-3" style="height: 200px; width: 100%; object-fit: cover;">
                                    <div class="card-body p-3">
                                        <h5>Спагети с кюфтенца</h5>
                                        <p class="small text-muted">Само за 30 минути можете да си приготвите...</p>
                                        <button class="btn btn-info text-white w-100 btn-teal">Прегледай</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 d-none d-md-block">
                                <div class="recipe-card bg-white rounded shadow position-relative mx-2">
                                    <div class="badge-new">НОВА РЕЦЕПТА</div>
                                    <img src="~/images/Moussaka.webp" class="card-img-top p-3" style="height: 200px; width: 100%; object-fit: cover;">
                                    <div class="card-body p-3">
                                        <h5>Мусаката на Баба</h5>
                                        <p class="small text-muted">Само за 30 минути можете да си приготвите...</p>
                                        <button class="btn btn-info text-white w-100 btn-teal">Прегледай</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Slide 2 -->
                    <div class="carousel-item">
                        <div class="row justify-content-center px-5 pt-4">
                            <div class="col-md-3">
                                <div class="recipe-card bg-white rounded shadow position-relative mx-2">
                                    <div class="badge-new">НОВА РЕЦЕПТА</div>
                                    <img src="~/images/Pizza.jpg" class="card-img-top p-3" style="height: 200px; width: 100%; object-fit: cover;">
                                    <div class="card-body p-3 text-center">
                                        <h5>Пица Маргарита</h5>
                                        <p class="small text-muted">Само за 30 минути можете да си приготвите...</p>
                                        <button class="btn btn-info text-white w-100 btn-teal">Прегледай</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Custom Arrows -->
                <button class="carousel-control-prev" type="button" data-bs-target="#seasonalCarousel" data-bs-slide="prev" style="width: 5%; opacity: 1;">
                    <span style="color: #5d4037; font-size: 3rem; font-weight: bold;">&lt;</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#seasonalCarousel" data-bs-slide="next" style="width: 5%; opacity: 1;">
                    <span style="color: #5d4037; font-size: 3rem; font-weight: bold;">&gt;</span>
                </button>
            </div>
        </div>
    </section>

    <!-- Most Viewed Section -->
    <section class="most-viewed py-5" style="background-color: #fff3e4">
        <div class="container text-center">
            <h2 class="mb-5" style="color: #5d4037; font-family: 'Georgia', serif;">Най-преглежданите рецепти</h2>

            <div id="mostViewedCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <!-- Slide 1 -->
                    <div class="carousel-item active">
                        <div class="row g-4 px-5">
                            @{
                                var recipes1 = new[] {
                                                        new { t = "Салата Цезар", c = "Salad_Caesar.jpg", b = "#ffbf69" },
                                                        new { t = "Мусаката на Баба", c = "Moussaka.webp", b = "#b1e1dd" },
                                                        new { t = "Яйчена салата", c = "qichena.jpg", b = "#ffbf69" },
                                                        new { t = "Крем брюле", c = "Creme_Brulee.jpg", b = "#b1e1dd" }
                                                        };
                            }
                            @foreach (var item in recipes1)
                            {
                                <div class="col-md-3">
                                    <div class="p-4 rounded shadow-sm h-100 card-zoom" style="background-color: @item.b;">
                                        <img src="~/images/@item.c" class="img-fluid rounded shadow-sm mb-3" style="height: 150px; width: 100%; object-fit: cover;">
                                        <h5 class="fw-bold">@item.t</h5>
                                        <p class="text-muted small">Традиционна рецепта</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    <!-- Slide 2 -->
                    <div class="carousel-item">
                        <div class="row g-4 px-5">
                            @{
                                var recipes2 = new[] {
                                                        new { t = "Шкембе чорба", c = "Shkembe.webp", b = "#ffbf69" },
                                                        new { t = "Сърми", c = "Sarmi.jpg", b = "#b1e1dd" },
                                                        new { t = "Баница", c = "Banitsa.jpg", b = "#ffbf69" },
                                                        new { t = "Каварма", c = "Kavarma.png", b = "#b1e1dd" }
                                                        };
                            }
                            @foreach (var item in recipes2)
                            {
                                <div class="col-md-3">
                                    <div class="p-4 rounded shadow-sm h-100 card-zoom" style="background-color: @item.b;">
                                        <img src="~/images/@item.c" class="img-fluid rounded shadow-sm mb-3" style="height: 150px; width: 100%; object-fit: cover;">
                                        <h5 class="fw-bold">@item.t</h5>
                                        <p class="text-muted small">Популярна рецепта</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Custom Arrows for Most Viewed -->
                <button class="carousel-control-prev custom-arrow teal-arrow" type="button" data-bs-target="#mostViewedCarousel" data-bs-slide="prev">
                    <span>&lt;</span>
                </button>
                <button class="carousel-control-next custom-arrow teal-arrow" type="button" data-bs-target="#mostViewedCarousel" data-bs-slide="next">
                    <span>&gt;</span>
                </button>
            </div>
        </div>
    </section>
</div>
