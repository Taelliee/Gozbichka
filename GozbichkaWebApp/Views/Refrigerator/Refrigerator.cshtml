@model GozbichkaWebApp.Models.ViewModels.RefrigeratorViewModel

@{
    ViewData["Title"] = "Моят Хладилник";
}

<div class="container py-5">
    <form asp-action="SearchRecipes" method="post" id="refrigeratorForm">
        <input type="hidden" asp-for="UserId" id="UserId" />

        <div id="fridgeDataStore" class="d-none">
            @foreach (var product in Model.AllProducts)
            {
                bool inFridge = Model.FridgeProductIds.Contains(product.ProductId);
                bool isActive = Model.ActiveSearchProductIds.Contains(product.ProductId);

                <div class="product-data"
                     data-id="@product.ProductId"
                     data-name="@product.ProductName"
                     data-in-fridge="@(inFridge ? "true" : "false")"
                     data-active="@(isActive ? "true" : "false")">
                </div>
            }
        </div>

        <div id="hiddenInputContainer"></div>

        <!-- Header -->
        <div class="d-flex align-items-center mb-5">
            <div class="me-4" style="min-width: 80px;">
                <svg width="80" height="100" viewBox="0 0 24 32" fill="none" stroke="#f39c12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="2" width="16" height="28" rx="2" ry="2"></rect>
                    <line x1="4" y1="10" x2="20" y2="10"></line>
                    <line x1="8" y1="5" x2="8" y2="7"></line>
                    <line x1="8" y1="14" x2="8" y2="18"></line>
                </svg>
            </div>
            <div>
                <h2 style="color: #5d4037; font-family: 'Georgia', serif; font-weight: bold;">Моят Хладилник</h2>
                <p class="text-muted fs-5 mb-0">Ще Ви помогнем да си намерите рецепта спрямо продуктите, които имате налични!</p>
            </div>
        </div>

        <!-- Combobox / Dropdown -->
        <div class="text-center mb-4">
            <div class="dropdown d-inline-block">
                <button class="btn text-dark fw-bold px-4 py-2" style="background-color: #ffcc80; border-radius: 8px; font-size: 1.1rem;" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                    Добави продукти <span class="ms-2 text-teal fw-bold fs-5">+</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-center shadow border-0 p-2" aria-labelledby="dropdownMenuButton" style="width: 300px; max-height: 400px; overflow-y: auto;">
                    <li class="mb-2"><input type="text" id="productSearch" class="form-control border-warning" placeholder="Търсене..."></li>
                    @foreach (var product in Model.AllProducts.OrderBy(p => p.ProductName))
                    {
                        <li><a class="dropdown-item product-dropdown-item rounded" href="#" data-id="@product.ProductId">@product.ProductName</a></li>
                    }
                </ul>
            </div>
        </div>

        <hr class="mb-5 mx-auto" style="width: 80%; border-top: 2px solid #ccc;">

        <div class="text-center mb-4">
            <h3 class="text-teal fw-bold" style="font-family: 'Georgia', serif;"><i class="bi bi-basket-fill text-orange"></i> НАЛИЧНИ ПРОДУКТИ</h3>
        </div>

        <!-- Chips Container -->
        <div id="chipsContainer" class="d-flex flex-wrap justify-content-center gap-3 mb-5 mx-auto" style="max-width: 800px;"></div>

        <!-- Action Buttons -->
        <div class="d-flex justify-content-end align-items-center gap-3 mx-auto" style="max-width: 800px;">
            <span id="saveIndicator" class="text-success fw-bold small" style="opacity: 0; transition: opacity 0.4s;">
                <i class="bi bi-cloud-check-fill"></i> Запазено
            </span>
            <button type="submit" id="btnSearch" class="btn text-white fw-bold px-5 py-2" style="background-color: #26c6da; border-radius: 25px; font-size: 1.1rem;">
                Търси рецепта
            </button>
        </div>
    </form>
</div>

<!-- Results Section -->
@if (Model.MatchingRecipes != null && Model.MatchingRecipes.Any())
{
    <div class="container-fluid py-5 mt-5" style="background-color: #ffcc80;">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 mb-4">
                    <h2 style="color: #5d4037; font-family: 'Georgia', serif;">Намерени рецепти</h2>
                    <p class="text-dark mt-3">Спрямо продуктите във вашия хладилник, ние ви предлагаме тези вкусни идеи!</p>
                </div>
                <div class="col-md-8">
                    <div class="row g-4">
                        @foreach (var recipe in Model.MatchingRecipes)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="recipe-card-brown p-3 rounded h-100 d-flex flex-column text-center shadow position-relative">
                                    <img src="@recipe.ImageURL" class="img-fluid rounded mb-3" style="object-fit: cover; height: 140px; width: 100%;">
                                    <h5 class="text-white fw-bold mb-3">@recipe.Title</h5>
                                    <div class="mt-auto">
                                        <p class="text-light small mb-0 opacity-75"><i class="bi bi-clock"></i> @recipe.CookingTime мин.</p>
                                        <a asp-controller="Recipes" asp-action="RecipeDetails" asp-route-id="@recipe.RecipeId" class="stretched-link" aria-label="Отвори рецептата @recipe.Title"></a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var userId = document.getElementById('UserId').value;
            
            renderChips();

            document.getElementById('productSearch').addEventListener('input', function() {
                var filter = this.value.toLowerCase();
                document.querySelectorAll('.product-dropdown-item').forEach(function(item) {
                    item.style.display = item.textContent.toLowerCase().includes(filter) ? 'block' : 'none';
                });
            });

            document.querySelectorAll('.product-dropdown-item').forEach(function(item) {
                item.addEventListener('click', function(e) {
                    e.preventDefault();
                    var dataEl = document.querySelector(`.product-data[data-id="${this.getAttribute('data-id')}"]`);
                    if (dataEl && dataEl.getAttribute('data-in-fridge') === 'false') {
                        dataEl.setAttribute('data-in-fridge', 'true');
                        dataEl.setAttribute('data-active', 'true');
                        renderChips();
                        triggerAutoSave();
                    }
                    document.getElementById('productSearch').value = '';
                    document.getElementById('productSearch').dispatchEvent(new Event('input'));
                });
            });

            function renderChips() {
                var container = document.getElementById('chipsContainer');
                container.innerHTML = ''; 
                document.querySelectorAll('.product-data[data-in-fridge="true"]').forEach(function(dataEl) {
                    var id = dataEl.getAttribute('data-id');
                    var name = dataEl.getAttribute('data-name');
                    var isActive = dataEl.getAttribute('data-active') === 'true';
                    
                    var chipClass = isActive ? 'chip-active' : 'chip-inactive';
                    var iconHtml = isActive ? '<i class="bi bi-check-circle text-teal"></i> ' : '';

                    container.innerHTML += `
                        <div class="product-chip shadow-sm ${chipClass}" onclick="toggleActive('${id}')">
                            ${iconHtml}${name}
                            <div class="remove-chip-btn" onclick="removeProduct(event, '${id}')"><i class="bi bi-x"></i></div>
                        </div>`;
                });
            }

            window.toggleActive = function(id) {
                var el = document.querySelector(`.product-data[data-id="${id}"]`);
                if (el) {
                    el.setAttribute('data-active', el.getAttribute('data-active') === 'true' ? 'false' : 'true');
                    renderChips();
                    triggerAutoSave();
                }
            };

            window.removeProduct = function(event, id) {
                event.stopPropagation();
                var el = document.querySelector(`.product-data[data-id="${id}"]`);
                if (el) {
                    el.setAttribute('data-in-fridge', 'false');
                    el.setAttribute('data-active', 'false');
                    renderChips();
                    triggerAutoSave();
                }
            };

            let saveTimeout;
            function triggerAutoSave() {
                var formData = new FormData();
                formData.append('userId', userId);
                
                document.querySelectorAll('.product-data[data-in-fridge="true"]').forEach(function(el) {
                    formData.append('fridgeProductIds', el.getAttribute('data-id'));
                    
                    if (el.getAttribute('data-active') === 'true') {
                        formData.append('activeSearchProductIds', el.getAttribute('data-id'));
                    }
                });

                fetch('@Url.Action("AutoSaveFridge", "Refrigerator")', { method: 'POST', body: formData })
                    .then(() => {
                        var ind = document.getElementById('saveIndicator');
                        ind.style.opacity = '1';
                        clearTimeout(saveTimeout);
                        saveTimeout = setTimeout(() => { ind.style.opacity = '0'; }, 2000);
                    });
            }

            document.getElementById('btnSearch').addEventListener('click', function() {
                var container = document.getElementById('hiddenInputContainer');
                container.innerHTML = '';
                
                document.querySelectorAll('.product-data[data-in-fridge="true"]').forEach(function(el) {
                     container.innerHTML += `<input type="hidden" name="FridgeProductIds" value="${el.getAttribute('data-id')}">`;
                });

                document.querySelectorAll('.product-data[data-in-fridge="true"][data-active="true"]').forEach(function(el) {
                     container.innerHTML += `<input type="hidden" name="ActiveSearchProductIds" value="${el.getAttribute('data-id')}">`;
                });
            });
        });
    </script>
}